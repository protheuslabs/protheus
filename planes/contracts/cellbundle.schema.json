{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CellBundle Manifest",
  "type": "object",
  "required": [
    "bundle_id",
    "version",
    "world",
    "capabilities",
    "budgets",
    "provenance"
  ],
  "properties": {
    "bundle_id": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "world": {
      "type": "string",
      "minLength": 1
    },
    "abi_version": {
      "type": "string",
      "minLength": 1
    },
    "component_target": {
      "type": "string",
      "minLength": 1
    },
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "budgets": {
      "type": "object",
      "required": [
        "cpu_ms",
        "ram_mb",
        "storage_mb",
        "network_kb",
        "tokens",
        "power_mw",
        "privacy_points",
        "cognitive_load"
      ],
      "properties": {
        "cpu_ms": { "type": "integer", "minimum": 0 },
        "ram_mb": { "type": "integer", "minimum": 0 },
        "storage_mb": { "type": "integer", "minimum": 0 },
        "network_kb": { "type": "integer", "minimum": 0 },
        "tokens": { "type": "integer", "minimum": 0 },
        "power_mw": { "type": "integer", "minimum": 0 },
        "privacy_points": { "type": "integer", "minimum": 0 },
        "cognitive_load": { "type": "integer", "minimum": 0 }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "source",
        "digest"
      ],
      "properties": {
        "source": { "type": "string", "minLength": 1 },
        "digest": { "type": "string", "minLength": 1 }
      }
    }
  }
}
