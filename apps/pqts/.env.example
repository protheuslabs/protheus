# Protheus Quant Trading System - Environment Variables
# Copy this file to .env and fill in your actual API keys

# ============================================
# BINANCE (Crypto Paper Trading)
# Get from: https://testnet.binance.vision/
# ============================================
BINANCE_TESTNET_API_KEY=your_binance_testnet_key_here
BINANCE_TESTNET_API_SECRET=your_binance_testnet_secret_here

# ============================================
# COINBASE PRO (Crypto Sandbox)
# Get from: https://public.sandbox.exchange.coinbase.com/
# ============================================
COINBASE_SANDBOX_API_KEY=your_coinbase_key_here
COINBASE_SANDBOX_SECRET=your_coinbase_secret_here
COINBASE_SANDBOX_PASSPHRASE=your_coinbase_passphrase_here

# ============================================
# ALPACA (Equities Paper Trading)
# Get from: https://app.alpaca.markets/paper/dashboard/overview
# ============================================
ALPACA_PAPER_API_KEY=your_alpaca_key_here
ALPACA_PAPER_API_SECRET=your_alpaca_secret_here

# ============================================
# OANDA (Forex Practice)
# Get from: https://www.oanda.com/demo-account/
# ============================================
OANDA_API_KEY=your_oanda_key_here
OANDA_ACCOUNT_ID=your_oanda_account_id_here

# ============================================
# DATABASE (Optional)
# ============================================
DATABASE_URL=sqlite:///data/pqts.db

# ============================================
# REDIS (Optional - for caching)
# ============================================
REDIS_URL=redis://localhost:6379/0
