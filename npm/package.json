{
  "name": "protheus",
  "version": "0.1.0",
  "description": "Thin npm distribution wrapper for the Protheus Rust CLI binary.",
  "license": "SEE LICENSE IN ../LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/protheuslabs/protheus.git"
  },
  "homepage": "https://github.com/protheuslabs/protheus",
  "bugs": {
    "url": "https://github.com/protheuslabs/protheus/issues"
  },
  "bin": {
    "protheus": "./bin/protheus.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "vendor/",
    "README.md"
  ],
  "scripts": {
    "postinstall": "node ./scripts/install.js",
    "test:smoke": "node ./scripts/smoke.js"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "protheus",
    "cli",
    "rust",
    "agents",
    "orchestration"
  ]
}
