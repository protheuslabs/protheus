{
  "version": "1.1",
  "enabled": true,
  "strict_default": true,
  "scan": {
    "include": [
      "client/runtime/systems",
      "client/runtime/lib",
      "client/runtime/config",
      "client/cli/bin",
      "client/cli/tools",
      "core",
      ".github/workflows",
      "package.json",
      "Cargo.toml"
    ],
    "ext": [
      ".ts",
      ".js",
      ".json",
      ".md",
      ".yml",
      ".yaml",
      ".sh",
      ".ps1"
    ],
    "forbidden_patterns": [
      "/Users/",
      "\\\\Users\\\\",
      "/home/"
    ],
    "allowlist": [
      "client/memory/",
      "local/state/",
      "docs/client/backlog_views/",
      "docs/workspace/SRS.md",
      "docs/workspace/UPGRADE_BACKLOG.md",
      "client/runtime/config/trusted_skills.json",
      "client/runtime/config/trusted_habits.json",
      "client/runtime/config/work_roots.json",
      "client/runtime/config/skill_install_policy.json",
      "client/runtime/config/backlog_registry.json",
      "client/runtime/config/backlog_review_registry.json",
      "client/runtime/config/relocatable_path_contract_policy.json",
      "core/layer0/memory_runtime/target/",
      "target/release/memory-cli"
    ]
  },
  "paths": {
    "latest_path": "client/runtime/local/state/ops/relocatable_path_contract/latest.json",
    "receipts_path": "client/runtime/local/state/ops/relocatable_path_contract/receipts.jsonl",
    "rewrite_inventory_path": "client/runtime/local/state/ops/relocatable_path_contract/path_rewrite_inventory.json"
  }
}
