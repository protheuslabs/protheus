{
  "version": "1.0",
  "enabled": true,
  "shadow_only": false,
  "strict_default": true,
  "sqlite": {
    "db_path": "local/state/kernel/state_kernel.db",
    "journal_mode": "WAL",
    "synchronous": "FULL",
    "foreign_keys": true,
    "busy_timeout_ms": 5000
  },
  "immutable": {
    "events_path": "local/state/kernel/events.jsonl",
    "receipts_path": "local/state/kernel/receipts.jsonl",
    "parity_path": "local/state/kernel/parity.json"
  },
  "outputs": {
    "latest_path": "local/state/kernel/latest.json",
    "migration_receipts_path": "local/state/kernel/migrations.receipts.jsonl",
    "replay_reports_path": "local/state/kernel/replay_reports.jsonl"
  },
  "attestation": {
    "enforce_on_write": true,
    "helix_latest_path": "local/state/helix/latest.json",
    "max_staleness_sec": 900,
    "allowed_decisions": [
      "clear",
      "shadow_advisory_clear"
    ]
  },
  "context_paths": {
    "soul_token_path": "local/state/security/soul_token_guard.json",
    "soul_biometric_path": "local/state/security/soul_biometric/latest.json",
    "identity_anchor_path": "local/state/autonomy/identity_anchor/latest.json",
    "heroic_echo_path": "local/state/autonomy/echo/latest.json"
  },
  "migration": {
    "strict_fail_on_unknown": true
  }
}
