{
  "schema_id": "schema_evolution_policy",
  "schema_version": "1.0",
  "enabled": true,
  "mode": "enforce",
  "default_n_minus_minor": 2,
  "auto_migrate_minor_drift": true,
  "max_auto_migrate_minor_delta": 6,
  "latest_path": "local/state/ops/schema_evolution/latest.json",
  "receipts_path": "local/state/ops/schema_evolution/receipts.jsonl",
  "lanes": [
    {
      "id": "primitive_catalog",
      "format": "json",
      "version_field": "schema_version",
      "target_version_ref": {
        "path": "client/runtime/config/primitive_catalog.json",
        "json_path": "schema_version"
      },
      "target_paths": [
        "client/runtime/config/primitive_catalog.json"
      ],
      "n_minus_minor": 0,
      "allow_missing_targets": false
    },
    {
      "id": "capability_profiles",
      "format": "json",
      "version_field": "schema_version",
      "target_version_ref": {
        "path": "client/runtime/config/capability_profile_schema.json",
        "json_path": "schema_version"
      },
      "target_paths": [
        "local/state/assimilation/capability_profiles/profiles"
      ],
      "n_minus_minor": 2,
      "allow_missing_targets": true,
      "max_depth": 4
    },
    {
      "id": "canonical_events",
      "format": "jsonl",
      "version_field": "schema_version",
      "target_version": "1.0",
      "target_paths": [
        "local/state/runtime/canonical_events/events.jsonl"
      ],
      "n_minus_minor": 2,
      "allow_missing_targets": true
    }
  ]
}
