{
  "version": "1.0",
  "enabled": true,
  "key_env": "REMOTE_EMERGENCY_HALT_KEY",
  "max_ttl_seconds": 300,
  "max_clock_skew_seconds": 30,
  "replay_nonce_ttl_seconds": 86400,
  "paths": {
    "state": "local/state/security/remote_emergency_halt_state.json",
    "nonce_store": "local/state/security/remote_emergency_halt_nonces.json",
    "audit": "local/state/security/remote_emergency_halt_audit.jsonl",
    "black_box_attestation_dir": "local/state/security/black_box_ledger/attestations"
  },
  "policy_root": {
    "enabled": true,
    "script": "client/runtime/systems/security/policy_rootd.ts",
    "scope": "workflow_external_orchestration",
    "source": "remote_emergency_halt",
    "timeout_ms": 15000,
    "require_lease_token": true
  },
  "revoke_leases": {
    "enabled": true,
    "lease_state_path": "local/state/security/capability_leases.json",
    "lease_audit_path": "local/state/security/capability_leases.jsonl"
  },
  "secure_purge": {
    "enabled": true,
    "allow_live_purge": false,
    "window_minutes_default": 15,
    "window_minutes_max": 60,
    "confirm_phrase": "I UNDERSTAND THIS PURGES SENSITIVE STATE",
    "quarantine_dir": "research/security/remote_halt_purge",
    "sensitive_paths": [
      "local/state/security/soul_token_guard.json",
      "local/state/security/release_attestations.jsonl",
      "local/state/security/capability_leases.json",
      "local/state/security/capability_leases.jsonl"
    ]
  }
}
