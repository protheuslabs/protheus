{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "event_stream": {
    "enabled": true,
    "publish": true,
    "stream": "spine.rsi_idle_hands_scheduler"
  },
  "quiet_hours_start": 23,
  "quiet_hours_end": 8,
  "min_interval_minutes": 15,
  "rsi_script": "client/cognition/adaptive/rsi/rsi_bootstrap.ts",
  "rsi_policy_path": "client/runtime/config/rsi_bootstrap_policy.json",
  "background_hands_script": "client/runtime/systems/spine/background_hands_scheduler.ts",
  "freshness_script": "client/runtime/systems/research/world_model_freshness_loop.ts",
  "budget_gate_script": "client/runtime/systems/ops/complexity_budget_gate.ts",
  "paths": {
    "memory_dir": "client/memory/spine/rsi_idle_hands_scheduler",
    "adaptive_index_path": "client/cognition/adaptive/spine/rsi_idle_hands_scheduler/index.json",
    "events_path": "local/state/spine/rsi_idle_hands_scheduler/events.jsonl",
    "latest_path": "local/state/spine/rsi_idle_hands_scheduler/latest.json",
    "receipts_path": "local/state/spine/rsi_idle_hands_scheduler/receipts.jsonl",
    "scheduler_state_path": "local/state/spine/rsi_idle_hands_scheduler/state.json"
  }
}
