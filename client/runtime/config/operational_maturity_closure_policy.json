{
  "version": "1.0",
  "enabled": true,
  "runbook_map_path": "client/runtime/config/autonomy_slo_runbook_map.json",
  "state_path": "local/state/ops/operational_maturity_closure/latest.json",
  "history_path": "local/state/ops/operational_maturity_closure/history.jsonl",
  "escalation": {
    "script": "client/runtime/systems/ops/alert_transport_health.ts",
    "args": [
      "run",
      "--strict=1"
    ],
    "timeout_ms": 30000
  },
  "classes": {
    "eyes": {
      "enabled": true,
      "retries": 2,
      "timeout_ms": 120000,
      "health": {
        "script": "client/cognition/habits/scripts/external_eyes.ts",
        "args": [
          "preflight",
          "--strict"
        ]
      },
      "remediate": {
        "script": "client/cognition/habits/scripts/external_eyes.ts",
        "args": [
          "preflight"
        ]
      }
    },
    "visualizer": {
      "enabled": true,
      "retries": 1,
      "timeout_ms": 40000,
      "health": {
        "script": "client/runtime/systems/ops/system_visualizer_guard.ts",
        "args": [
          "check",
          "--strict=1"
        ]
      },
      "remediate": {
        "script": "client/runtime/systems/ops/system_visualizer_guard.ts",
        "args": [
          "restart"
        ]
      }
    },
    "alert_transport": {
      "enabled": true,
      "retries": 1,
      "timeout_ms": 40000,
      "health": {
        "script": "client/runtime/systems/ops/alert_transport_health.ts",
        "args": [
          "run",
          "--strict=1"
        ]
      },
      "remediate": {
        "script": "client/runtime/systems/ops/alert_transport_health.ts",
        "args": [
          "run"
        ]
      }
    }
  }
}
