{
  "version": "1.0",
  "enabled": true,
  "blocked_globs": [
    "local/state/**",
    "tmp/**",
    "client/runtime/local/logs/**",
    "dist/**"
  ],
  "allow_globs": [
    "local/state/README.md",
    "local/state/**/.gitkeep"
  ],
  "outputs": {
    "latest_path": "local/state/ops/repo_hygiene_generated_guard/latest.json",
    "history_path": "local/state/ops/repo_hygiene_generated_guard/history.jsonl"
  }
}
