{
  "version": "1.0",
  "enabled": true,
  "max_age_days": 14,
  "roots": ["state", "tmp", "logs"],
  "allowed_suffixes": [".json", ".jsonl", ".tmp", ".log", ".ndjson", ".txt"],
  "exclude_prefixes": [
    "local/state/ops/cleanup",
    "local/state/security",
    "local/state/autonomy/receipt_dashboard"
  ],
  "dry_run_default": true,
  "paths": {
    "quarantine_dir": "local/state/ops/cleanup/quarantine",
    "latest_path": "local/state/ops/cleanup/latest.json",
    "history_path": "local/state/ops/cleanup/history.jsonl"
  }
}
