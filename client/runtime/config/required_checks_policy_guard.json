{
  "version": "1.0",
  "enabled": true,
  "files": {
    "codeowners": ".github/CODEOWNERS",
    "required_checks_workflow": ".github/workflows/required-checks.yml",
    "branch_protection_doc": "docs/client/BRANCH_PROTECTION_POLICY.md",
    "package_json": "package.json"
  },
  "required_checks": [
    "ci_suite",
    "contract_check",
    "schema_contract_check",
    "adaptive_layer_guard_strict"
  ],
  "required_npm_scripts": [
    "guard:merge",
    "guard:merge:fast"
  ],
  "outputs": {
    "latest_path": "local/state/security/required_checks_policy_guard/latest.json",
    "history_path": "local/state/security/required_checks_policy_guard/history.jsonl"
  }
}
