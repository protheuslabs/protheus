{
  "schema_id": "security_review_program_policy",
  "schema_version": "1.0",
  "cadence_days": 90,
  "mode": "fail_closed",
  "threat_model": {
    "path": "docs/client/security/THREAT_MODEL.md",
    "refresh_required_each_cycle": true
  },
  "independent_review": {
    "minimum_reviewers": 2,
    "checklist_path": "docs/client/security/SECURITY_REVIEW_CHECKLIST.md",
    "allow_internal_security_peer_review": true
  },
  "remediation_sla_days": {
    "critical": 7,
    "high": 30,
    "medium": 90
  },
  "release_block": {
    "block_on_open_severity": [
      "critical"
    ],
    "exception_expiry_days": 14,
    "require_signed_exception_owner": true
  },
  "outputs": {
    "latest_path": "local/state/security/review_program/latest.json",
    "history_path": "local/state/security/review_program/history.jsonl",
    "exceptions_path": "local/state/security/review_program/exceptions.jsonl"
  }
}
