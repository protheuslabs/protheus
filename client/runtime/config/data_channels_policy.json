{
  "version": "1.0",
  "channels": {
    "memory": {
      "roots": [
        "client/memory/"
      ],
      "controllers": [
        "client/runtime/systems/memory/"
      ],
      "purpose": "Curated and node-based memory"
    },
    "adaptive": {
      "roots": [
        "client/cognition/adaptive/",
        "local/state/client/cognition/adaptive/"
      ],
      "controllers": [
        "client/runtime/systems/adaptive/"
      ],
      "purpose": "Adaptive layer data + receipts"
    },
    "runtime_state_logs": {
      "roots": [
        "local/state/",
        "client/runtime/local/logs/",
        "client/runtime/local/logs/habits/"
      ],
      "controllers": [
        "client/runtime/systems/spine/",
        "client/runtime/systems/autonomy/",
        "client/runtime/systems/security/",
        "client/runtime/systems/sensory/",
        "client/runtime/systems/routing/",
        "client/runtime/systems/reflex/",
        "client/runtime/systems/spawn/",
        "client/runtime/systems/budget/"
      ],
      "purpose": "Operational state, audits, telemetry"
    },
    "secrets": {
      "repo_scaffold": [
        "client/runtime/local/secrets/"
      ],
      "external_root_default": "~/.client/runtime/config/protheus/client/runtime/local/secrets/",
      "controllers": [
        "client/runtime/lib/secret_broker.ts",
        "client/runtime/systems/security/secret_broker.ts"
      ],
      "purpose": "Secret values and key material outside git"
    }
  },
  "notes": [
    "Controllers mutate their channel; other modules should use controller interfaces.",
    "External secrets location is configurable via SECRET_BROKER_SECRETS_DIR."
  ]
}
