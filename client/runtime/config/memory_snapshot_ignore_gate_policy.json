{
  "version": "1.0",
  "enabled": true,
  "required_channels": [
    "state_backup",
    "offsite_state_backup"
  ],
  "backup_integrity_script": "systems/ops/backup_integrity_check.js",
  "gitignore_path": "../.gitignore",
  "snapshot_patterns": [
    "client/runtime/local/memory/_snapshots/",
    "client/memory/*.backup.*",
    "local/state/client/memory/snapshots/*.json",
    "local/state/client/memory/snapshots/*.jsonl"
  ],
  "outputs": {
    "latest_path": "local/state/ops/memory_snapshot_ignore_gate/latest.json",
    "history_path": "local/state/ops/memory_snapshot_ignore_gate/history.jsonl"
  }
}
