{
  "version": "1.0",
  "enabled": true,
  "default_runtime_transport": "daemon_first",
  "strict_build_requires_cargo": false,
  "commands": {
    "rust_build": ["cargo", "build", "--manifest-path", "core/layer0/memory_runtime/Cargo.toml", "--release"],
    "rust_probe": ["cargo", "run", "--quiet", "--manifest-path", "core/layer0/ops/Cargo.toml", "--bin", "protheus-ops", "--", "memory-ambient", "status", "--json"]
  },
  "matrix": {
    "profiles": [
      {
        "id": "daemon_first",
        "role": "production_default",
        "description": "Daemon-first transport with deterministic fallback (napi -> daemon -> cli -> js emergency).",
        "run_command": "node client/runtime/systems/memory/memory_recall.ts query --q=\"probe\" --top=1"
      },
      {
        "id": "napi_optional",
        "role": "performance_optional",
        "description": "In-process N-API lane when native module exists; fallback remains daemon/cli.",
        "run_command": "MEMORY_RECALL_RUST_NAPI_ENABLED=1 node client/runtime/systems/memory/memory_recall.ts query --q=\"probe\" --top=1"
      },
      {
        "id": "cli_compat",
        "role": "legacy_compat",
        "description": "Direct Rust memory-cli path for compatibility and diagnostics only.",
        "run_command": "cargo run --manifest-path core/layer0/memory_runtime/Cargo.toml --bin memory-cli -- query-index --q probe --root=."
      }
    ]
  },
  "paths": {
    "state_path": "local/state/client/memory/napi_build_surface_compat/state.json",
    "latest_path": "local/state/client/memory/napi_build_surface_compat/latest.json",
    "receipts_path": "local/state/client/memory/napi_build_surface_compat/receipts.jsonl",
    "matrix_json_path": "local/state/client/memory/napi_build_surface_compat/build_matrix.json",
    "matrix_md_path": "docs/client/MEMORY_BUILD_SURFACE.md"
  }
}
