{
  "version": "1.0",
  "enabled": true,
  "shadow_only": true,
  "target_profiles": [
    "phone_seed",
    "desktop_seed",
    "cluster_seed"
  ],
  "package_cmd": [
    "node",
    "client/runtime/systems/ops/protheus_prime_seed.ts",
    "package",
    "--strict=1"
  ],
  "verify_cmd": [
    "node",
    "client/runtime/systems/ops/protheus_prime_seed.ts",
    "verify",
    "--strict=1"
  ],
  "paths": {
    "latest_path": "local/state/ops/universal_distribution_plane/latest.json",
    "receipts_path": "local/state/ops/universal_distribution_plane/receipts.jsonl",
    "manifest_path": "local/state/ops/universal_distribution_plane/distribution_manifest.json"
  }
}
