{
  "version": "1.0",
  "enabled": true,
  "strict_default": false,
  "signing": {
    "key_env": "PROTHEUS_MIGRATION_SIGNING_KEY",
    "default_key": "migration_dev_key",
    "algorithm": "sha256"
  },
  "expected_surfaces": [
    {
      "id": "config",
      "path": "config",
      "required": true
    },
    {
      "id": "habits",
      "path": "habits",
      "required": false
    },
    {
      "id": "vault",
      "path": "client/runtime/local/secrets/vault",
      "required": false
    },
    {
      "id": "memory",
      "path": "memory",
      "required": true
    },
    {
      "id": "science",
      "path": "local/state/science",
      "required": false
    },
    {
      "id": "routing",
      "path": "local/state/routing",
      "required": false
    }
  ],
  "core_bridge": {
    "registry_path": "local/state/migration/core_bridge/registry.json",
    "checkpoints_root": "local/state/migration/core_bridge/checkpoints"
  },
  "paths": {
    "latest_path": "local/state/migration/post_migration_verification/latest.json",
    "receipts_path": "local/state/migration/post_migration_verification/receipts.jsonl",
    "reports_root": "local/state/migration/post_migration_verification/reports"
  }
}
