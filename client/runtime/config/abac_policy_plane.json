{
  "version": "v1",
  "kind": "abac_policy_plane",
  "default_effect": "deny",
  "rules": [
    {
      "id": "allow_research_public_read",
      "effect": "allow",
      "subject": {"role": ["researcher", "operator"]},
      "object": {"classification": ["public"]},
      "action": ["read"],
      "context": {"env": ["dev", "prod"]}
    },
    {
      "id": "deny_external_write_without_trust",
      "effect": "deny",
      "subject": {"role": ["researcher", "operator", "automation"]},
      "object": {"classification": ["restricted", "internal"]},
      "action": ["write", "publish"],
      "context": {"trust": ["unverified"]}
    }
  ],
  "flight_recorder": {
    "immutable": true,
    "hash_chain": true,
    "redact_subject_fields": ["email", "token"]
  }
}
