{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "risk": {
    "default_tier": 2,
    "require_explicit_approval_tier": 3
  },
  "event_stream": {
    "enabled": true,
    "publish": true,
    "stream": "security.mcp_a2a_venom_gate"
  },
  "fail_closed": true,
  "venom_script": "client/runtime/systems/security/venom_containment_layer.ts",
  "routes": {
    "mcp_discover": {
      "script": "adapters/cognition/skills/mcp/mcp_gateway.ts",
      "args": [
        "discover",
        "--query=memory",
        "--risk-tier=2"
      ]
    },
    "a2a_delegate": {
      "script": "client/runtime/systems/a2a/a2a_delegation_plane.ts",
      "args": [
        "execute",
        "--owner=system",
        "--task=delegate",
        "--risk-tier=2"
      ]
    }
  },
  "contract_lanes": [
    {
      "id": "RR-001",
      "script": "client/runtime/systems/ops/config_flag_conflict_check.ts",
      "check_cmd": "check"
    },
    {
      "id": "RR-002",
      "script": "client/runtime/systems/ops/canonical_execution_path_check.ts",
      "check_cmd": "check"
    }
  ],
  "paths": {
    "memory_dir": "client/memory/security/mcp_a2a_venom_contract_gate",
    "adaptive_index_path": "client/cognition/adaptive/security/mcp_a2a_venom_contract_gate/index.json",
    "events_path": "local/state/security/mcp_a2a_venom_contract_gate/events.jsonl",
    "latest_path": "local/state/security/mcp_a2a_venom_contract_gate/latest.json",
    "receipts_path": "local/state/security/mcp_a2a_venom_contract_gate/receipts.jsonl"
  }
}
