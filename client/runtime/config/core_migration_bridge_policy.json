{
  "version": "1.0",
  "enabled": true,
  "strict_default": false,
  "signing": {
    "key_env": "PROTHEUS_MIGRATION_SIGNING_KEY",
    "default_key": "migration_dev_key",
    "algorithm": "sha256"
  },
  "git": {
    "update_remote": true,
    "remote_name": "origin",
    "auto_init_target_repo": true
  },
  "workspace": {
    "default_parent": ".."
  },
  "transfer_surfaces": [
    {
      "id": "config",
      "source": "config",
      "target": "config",
      "required": true
    },
    {
      "id": "habits",
      "source": "habits",
      "target": "habits",
      "required": false
    },
    {
      "id": "vault",
      "source": "client/runtime/local/secrets/vault",
      "target": "client/runtime/local/secrets/vault",
      "required": false
    },
    {
      "id": "memory",
      "source": "memory",
      "target": "memory",
      "required": true
    },
    {
      "id": "scientific_receipts",
      "source": "local/state/science",
      "target": "local/state/science",
      "required": false
    },
    {
      "id": "scientific_mode_v4_receipts",
      "source": "local/state/science/scientific_mode_v4",
      "target": "local/state/science/scientific_mode_v4",
      "required": false
    },
    {
      "id": "research_receipts",
      "source": "local/state/research",
      "target": "local/state/research",
      "required": false
    }
  ],
  "paths": {
    "latest_path": "local/state/migration/core_bridge/latest.json",
    "receipts_path": "local/state/migration/core_bridge/receipts.jsonl",
    "checkpoints_root": "local/state/migration/core_bridge/checkpoints",
    "registry_path": "local/state/migration/core_bridge/registry.json"
  }
}
