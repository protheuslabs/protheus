{
  "schema_id": "scale_envelope_policy",
  "schema_version": "1.0",
  "parity_threshold": 1,
  "profiles": [
    {
      "id": "phone_seed",
      "surface_budget": 0.35,
      "max_parallel": 1
    },
    {
      "id": "desktop_seed",
      "surface_budget": 0.7,
      "max_parallel": 4
    },
    {
      "id": "cluster_sim",
      "surface_budget": 1,
      "max_parallel": 16
    }
  ],
  "scenarios": [
    {
      "id": "command_shell_guard",
      "kind": "command",
      "command": "node client/runtime/systems/autonomy/strategy_execute_guard.ts run <date>",
      "step_type": "command"
    },
    {
      "id": "command_external_actuation",
      "kind": "command",
      "command": "node client/runtime/systems/actuation/actuation_executor.ts run --kind=http_request --params={\"url\":\"https://example.com\"}",
      "step_type": "external"
    },
    {
      "id": "command_receipt_check",
      "kind": "command",
      "command": "local/state/client/cognition/adaptive/workflows/executor/receipts/latest.json",
      "step_type": "receipt"
    },
    {
      "id": "adapter_payment",
      "kind": "adapter",
      "adapter": "payment_task"
    },
    {
      "id": "adapter_filesystem",
      "kind": "adapter",
      "adapter": "filesystem_task"
    }
  ]
}
