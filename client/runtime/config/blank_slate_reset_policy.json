{
  "version": "1.0",
  "default_profile": "adaptive_memory_blank_slate",
  "profiles": {
    "adaptive_memory_blank_slate": {
      "description": "Archive adaptive-state + memory artifacts for reversible blank-slate tests.",
      "includes": [
        "client/runtime/local/adaptive/sensory/eyes/catalog.json",
        "client/runtime/local/adaptive/sensory/eyes/focus_triggers.json",
        "client/cognition/adaptive/strategy/registry.json",
        "local/workspace/assistant/SOUL.md",
        "local/workspace/assistant/USER.md",
        "local/workspace/assistant/IDENTITY.md",
        "local/workspace/assistant/HEARTBEAT.md",
        "local/workspace/assistant/MEMORY.md",
        "local/workspace/memory/*.md",
        "local/workspace/reports/MEMORY_INDEX.md",
        "local/workspace/reports/TAGS_INDEX.md",
        "local/workspace/reports/LEARNINGS_INDEX.md",
        "local/state/client/cognition/adaptive/reflex/pool_state.json",
        "local/state/client/cognition/adaptive/strategy/outcome_fitness.json",
        "local/state/client/cognition/adaptive/strategy/outcome_fitness/*.json",
        "local/state/client/cognition/adaptive/strategy/scorecards/*.json",
        "local/state/client/cognition/adaptive/strategy/snapshots/*.json",
        "local/state/client/cognition/adaptive/suggestions/*.json",
        "client/memory/*.md",
        "client/memory/*.md.backup.*",
        "client/runtime/local/memory/heartbeat-state.json",
        "client/memory/_archive",
        "client/runtime/local/memory/.rebuild_delta_cache.json",
        "client/runtime/local/memory/_snapshots",
        "client/runtime/local/memory/core_profiles",
        "client/runtime/local/memory/spine/preferences",
        "client/memory/handoff",
        "client/memory/reports",
        "client/runtime/local/memory/state"
      ],
      "exclude_exact": [
        "client/memory/README.md"
      ],
      "exclude_prefixes": [
        "scripts/memory"
      ],
      "exclude_suffixes": [
        ".jsonl"
      ]
    }
  }
}
