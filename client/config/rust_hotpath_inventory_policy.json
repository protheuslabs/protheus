{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "paths": {
    "latest_path": "state/ops/rust_hotpath_inventory/latest.json",
    "history_path": "state/ops/rust_hotpath_inventory/history.jsonl"
  },
  "scan": {
    "roots": ["systems", "lib"],
    "include_extensions": [".ts", ".rs"],
    "exclude_dirs": [".git", "node_modules", "dist", "state", "tmp", "target", "coverage"]
  },
  "report": {
    "top_directories": 15,
    "top_files": 30,
    "milestones": [15, 25, 35, 50]
  }
}
