  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "owner_id": "browser_session_vault",
  "event_stream": { "enabled": true, "publish": true, "stream": "browser.session_vault" },
  "encryption_key": "dev_browser_session_key",
  "paths": {
