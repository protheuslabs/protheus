{
  "schema_id": "conflict_marker_guard_policy",
  "schema_version": "1.0",
  "scope": {
    "prefixes": [
      "client/systems/",
      "client/config/",
      "client/docs/",
      "client/lib/",
      "client/deploy/"
    ],
    "extensions": [
      ".ts",
      ".js",
      ".json",
      ".md",
      ".yaml",
      ".yml",
      ".toml",
      ".sh"
    ],
    "exclude_paths": []
  },
  "max_violations_reported": 200
}
