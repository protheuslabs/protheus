{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "risk": {
    "default_tier": 2,
    "require_explicit_approval_tier": 3
  },
  "event_stream": {
    "enabled": true,
    "publish": true,
    "stream": "memory.hierarchical_views"
  },
  "paths": {
    "memory_dir": "client/memory/views",
    "adaptive_index_path": "client/adaptive/client/memory/views/index.json",
    "events_path": "state/memory\/hierarchical_views/events.jsonl",
    "latest_path": "state/memory\/hierarchical_views/latest.json",
    "receipts_path": "state/memory\/hierarchical_views/receipts.jsonl"
  }
}
