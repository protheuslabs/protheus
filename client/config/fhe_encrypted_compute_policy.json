{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "allowlisted_operations": [
    "sum",
    "mean",
    "max"
  ],
  "risk": {
    "default_tier": 2,
    "require_explicit_approval_tier": 3
  },
  "event_stream": {
    "enabled": true,
    "publish": true,
    "stream": "crypto.fhe_pilot"
  },
  "paths": {
    "memory_dir": "client/memory/crypto/fhe",
    "adaptive_index_path": "client/adaptive/crypto/fhe/index.json",
    "events_path": "state/crypto/fhe_pilot/events.jsonl",
    "latest_path": "state/crypto/fhe_pilot/latest.json",
    "receipts_path": "state/crypto/fhe_pilot/receipts.jsonl"
  }
}
