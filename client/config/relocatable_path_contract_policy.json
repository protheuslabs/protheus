{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "scan": {
    "include": ["systems", "lib", "config", "bin", ".github", "package.json"],
    "ext": [".ts", ".js", ".json", ".md", ".yml", ".yaml"],
    "forbidden_patterns": ["/Users/", "\\\\Users\\\\", "/home/"],
    "allowlist": [
      "client/memory/",
      "state/",
      "client/docs/backlog_views/",
      "SRS.md",
      "UPGRADE_BACKLOG.md",
      "client/config/trusted_skills.json",
      "client/config/trusted_habits.json",
      "client/config/work_roots.json",
      "client/config/skill_install_policy.json",
      "client/config/backlog_registry.json",
      "client/config/backlog_review_registry.json",
      "core/layer0/memory_runtime/target/",
      "target/release/memory-cli"
    ]
  },
  "paths": {
    "latest_path": "state/ops/relocatable_path_contract/latest.json",
    "receipts_path": "state/ops/relocatable_path_contract/receipts.jsonl",
    "rewrite_inventory_path": "state/ops/relocatable_path_contract/path_rewrite_inventory.json"
  }
}
