{
  "constitution_path": "AGENT-CONSTITUTION.md",
  "guard_registry_path": "client/config/guard_check_registry.json",
  "required_constitution_markers": [
    "Mind Sovereignty Covenant",
    "RSI Guardrails"
  ],
  "required_guard_checks": [
    "contract_check",
    "formal_invariant_engine"
  ],
  "command_required_capabilities": {
    "start_agent": "agent.lifecycle",
    "stop_agent": "agent.lifecycle",
    "query_receipt_chain": "receipt.read",
    "list_active_agents": "system.read",
    "get_system_status": "system.read",
    "apply_policy_update": "policy.update",
    "install_extension": "extension.install"
  },
  "allow_policy_update_prefixes": [
    "constitution_safe/"
  ],
  "bridge_message_budget_max": 10,
  "rate_limit": {
    "window_ms": 1000,
    "per_client_max": 60,
    "per_client_command_max": 20
  }
}
