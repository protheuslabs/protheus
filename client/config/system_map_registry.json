{
  "version": "1.0",
  "entries": [
    {
      "id": "layer_minus_one_exotic_wrapper",
      "subsystem": "Exotic Wrapper",
      "layer": "Layer -1",
      "owner": "core",
      "purpose": "Normalizes exotic substrate signals into deterministic Layer 0 envelopes.",
      "inbound": ["substrate probes", "adapter capability metadata"],
      "outbound": ["layer0 envelope", "degradation contract"],
      "failure_mode": "unsupported_substrate_profile",
      "health_check": "cargo check -p exotic_wrapper",
      "srs": ["V6-ARCH-LAYERING-031"]
    },
    {
      "id": "origin_integrity",
      "subsystem": "Origin Integrity",
      "layer": "Layer 0",
      "owner": "core",
      "purpose": "Enforces infallible-origin checks before autonomous runtime actions.",
      "inbound": ["startup self-audit", "manual origin verify"],
      "outbound": ["origin integrity receipt", "degraded/fail-closed decision"],
      "failure_mode": "origin_integrity_timeout_or_mismatch",
      "health_check": "protheus-ops origin-integrity status",
      "srs": ["V6-ORIGIN-001", "V6-ORIGIN-004"]
    },
    {
      "id": "importance_kernel",
      "subsystem": "Global Importance Kernel",
      "layer": "Layer 0",
      "owner": "core",
      "purpose": "Scores cross-system events and assigns deterministic priority/initiative actions.",
      "inbound": ["attention queue event", "severity and context metadata"],
      "outbound": ["score", "band", "priority", "initiative_action"],
      "failure_mode": "layer2_priority_authority_unavailable",
      "health_check": "npm run -s ops:test:protheus-ops-core:attention",
      "srs": ["V6-INITIATIVE-013"]
    },
    {
      "id": "attention_queue",
      "subsystem": "Attention Queue",
      "layer": "Layer 0",
      "owner": "core",
      "purpose": "Maintains TTL/dedupe/backpressure-governed priority event queue.",
      "inbound": ["eyes", "memory auto-recall", "dopamine", "spine", "shadow dispatch"],
      "outbound": ["priority-ordered events", "cursor/ack receipts"],
      "failure_mode": "queue_backpressure_or_gate_active",
      "health_check": "protheus-ops attention-queue status",
      "srs": ["V6-COCKPIT-002", "V6-COCKPIT-006", "V6-INITIATIVE-013"]
    },
    {
      "id": "swarm_router",
      "subsystem": "Swarm Router",
      "layer": "Layer 0",
      "owner": "core",
      "purpose": "Provides typed task routing with retry, scaling, and queue contracts.",
      "inbound": ["coordinator tasks", "worker status"],
      "outbound": ["route decisions", "in-flight metrics", "recovery receipts"],
      "failure_mode": "cargo_test_timeout_host_stall",
      "health_check": "cargo test -p swarm_router",
      "srs": ["V6-SWARM-001", "V6-SWARM-006"]
    },
    {
      "id": "adaptive_runtime_core",
      "subsystem": "Adaptive Runtime (Core)",
      "layer": "Layer 0",
      "owner": "core",
      "purpose": "Owns adaptation cadence/resource contracts and emits deterministic adaptation receipts.",
      "inbound": ["adaptive tick", "runtime metrics"],
      "outbound": ["adaptation receipt", "status snapshot"],
      "failure_mode": "adaptive_policy_guard_denied",
      "health_check": "protheus-ops adaptive-runtime status",
      "srs": ["V6-ADAPT-CORE-001"]
    },
    {
      "id": "layer2_initiative_primitives",
      "subsystem": "Initiative Primitives",
      "layer": "Layer 2",
      "owner": "core",
      "purpose": "Provides deterministic initiative score/action primitives for cockpit-safe proactive behavior.",
      "inbound": ["importance payload", "attention metadata"],
      "outbound": ["initiative action", "priority shaping"],
      "failure_mode": "layer2_execution_lane_unavailable",
      "health_check": "npm run -s ops:test:execution-core:initiative",
      "srs": ["V6-ARCH-ICEBERG-028", "V6-INITIATIVE-013"]
    },
    {
      "id": "conduit_bridge",
      "subsystem": "Conduit Bridge",
      "layer": "Cross-Plane",
      "owner": "core+client",
      "purpose": "Enforces conduit-only communication between client surfaces and core authority.",
      "inbound": ["client lane request", "daemon probes"],
      "outbound": ["typed conduit response", "runtime gate diagnostics"],
      "failure_mode": "conduit_stdio_timeout_or_runtime_gate",
      "health_check": "node client/lib/conduit_full_lifecycle_probe.js",
      "srs": ["V6-COCKPIT-005", "V6-CONDUIT-RUNTIME-STALL-001"]
    },
    {
      "id": "protheusd",
      "subsystem": "Persistent Cockpit Daemon",
      "layer": "Client Ops",
      "owner": "client",
      "purpose": "Attach-first daemon that keeps ambient loop, subscribe lane, and resident state alive across sessions.",
      "inbound": ["attach/start/subscribe commands", "attention queue drain"],
      "outbound": ["status envelopes", "degraded class diagnostics", "subscribe batches"],
      "failure_mode": "bridge_degraded_or_origin_pending",
      "health_check": "node client/systems/ops/protheusd.js status",
      "srs": ["V6-COCKPIT-001", "V6-COCKPIT-004", "V6-COCKPIT-005"]
    },
    {
      "id": "cockpit_harness",
      "subsystem": "Cockpit Harness",
      "layer": "Client Ops",
      "owner": "client",
      "purpose": "Surfaces critical ambient alerts and cockpit-ready telemetry for mech-suit operation.",
      "inbound": ["daemon status", "alert events"],
      "outbound": ["cockpit alert artifacts", "harness receipts"],
      "failure_mode": "alert_publish_failed",
      "health_check": "node client/systems/ops/cockpit_harness.js status",
      "srs": ["V6-MECH-014"]
    },
    {
      "id": "sensory_eyes",
      "subsystem": "Eyes/Sensory Intake",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Collects external signals and routes governed events to memory/attention lanes.",
      "inbound": ["collectors", "eye directives"],
      "outbound": ["signal events", "memory bridge entries"],
      "failure_mode": "collector_failure_or_route_denied",
      "health_check": "node client/systems/sensory/eyes_intake.js status",
      "srs": ["V6-SHADOW-003"]
    },
    {
      "id": "conversation_eye",
      "subsystem": "Conversation Eye",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Synthesizes dialogue into tagged memory nodes and forwards recall triggers.",
      "inbound": ["session messages"],
      "outbound": ["conversation nodes", "auto-recall triggers"],
      "failure_mode": "synthesis_write_failed",
      "health_check": "npm run -s test:ops:conversation-eye-collector",
      "srs": ["V6-COGNITION-010"]
    },
    {
      "id": "memory_matrix",
      "subsystem": "Memory Matrix",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Maintains scored tag-to-memory index for low-burn retrieval and ranking.",
      "inbound": ["daily nodes", "conversation eye", "dream flags"],
      "outbound": ["ranked matrix entries", "tag coverage"],
      "failure_mode": "matrix_rebuild_failed",
      "health_check": "npm run -s test:memory:matrix",
      "srs": ["V6-MEMORY-011"]
    },
    {
      "id": "dream_sequencer",
      "subsystem": "Dream Sequencer",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Periodically reorders memory relevance and refreshes top-priority recall surfaces.",
      "inbound": ["memory matrix"],
      "outbound": ["reordered priorities", "dream sequence receipts"],
      "failure_mode": "dream_cycle_degraded",
      "health_check": "npm run -s memory:dream-sequencer:status",
      "srs": ["V6-MEMORY-011"]
    },
    {
      "id": "memory_auto_recall",
      "subsystem": "Memory Auto-Recall",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Pushes bounded high-overlap memory matches into attention without full-file scans.",
      "inbound": ["new memory node", "tag overlap matrix"],
      "outbound": ["attention queue enqueue"],
      "failure_mode": "attention_enqueue_failed",
      "health_check": "npm run -s test:memory:auto-recall",
      "srs": ["V6-MEMORY-011"]
    },
    {
      "id": "shadow_signal_classifier",
      "subsystem": "Shadow Signal Classifier",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Classifies sensory signals into shadow routes with confidence and reason receipts.",
      "inbound": ["eye signals"],
      "outbound": ["shadow route map", "classifier receipt"],
      "failure_mode": "no_route_match",
      "health_check": "npm run -s test:lane:v6-shadow-003",
      "srs": ["V6-SHADOW-003"]
    },
    {
      "id": "shadow_dispatch_reliability",
      "subsystem": "Shadow Dispatch Reliability",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Provides idempotent enqueue/retry/ack dispatch contract for routed shadow tasks.",
      "inbound": ["classifier route", "dispatch request"],
      "outbound": ["dispatch queue state", "escalation/ack receipts"],
      "failure_mode": "dispatch_queue_stall",
      "health_check": "npm run -s test:lane:v6-shadow-004",
      "srs": ["V6-SHADOW-004"]
    },
    {
      "id": "browser_text_diff",
      "subsystem": "Browser Text/Diff Lane",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Emits token-efficient browser text snapshots and compact diffs instead of heavy payloads.",
      "inbound": ["html/text snapshot", "before/after text"],
      "outbound": ["text snapshot receipt", "diff receipt with token reduction"],
      "failure_mode": "snapshot_parse_failed",
      "health_check": "npm run -s test:lane:v6-browser-007",
      "srs": ["V6-BROWSER-007"]
    },
    {
      "id": "adaptive_loop_client",
      "subsystem": "Realtime Adaptation Loop",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Applies interaction-driven adaptation under drift/covenant gates with continuity checks.",
      "inbound": ["interaction/heartbeat triggers", "resource metrics"],
      "outbound": ["adaptation cycle receipts", "review bridge submissions"],
      "failure_mode": "cadence_throttle_or_drift_gate",
      "health_check": "npm run -s test:lane:v6-adapt-004",
      "srs": ["V6-ADAPT-004", "V6-ADAPT-005", "V6-ADAPT-006"]
    },
    {
      "id": "reflexes",
      "subsystem": "Low-Burn Reflexes",
      "layer": "Client Cognition",
      "owner": "client",
      "purpose": "Provides capped helper reflexes for common tasks without large token overhead.",
      "inbound": ["reflex request"],
      "outbound": ["bounded reflex response"],
      "failure_mode": "token_cap_violation",
      "health_check": "npm run -s test:reflexes",
      "srs": ["V6-REFLEX-CORE-001"]
    }
  ]
}
