{
  "version": "1.0",
  "enabled": true,
  "shadow_only": true,
  "paths": {
    "benchmark_path": "state/client/memory/rust_transition/benchmark_history.json",
    "benchmark_latest_path": "state/client/memory/rust_transition/benchmark_latest.json",
    "benchmark_report_path": "benchmarks/memory-stage1.md"
  },
  "benchmark": {
    "mode": "probe_commands",
    "timeout_ms": 30000,
    "require_rust_backend_used": true,
    "require_rust_transport": "any",
    "enforce_warm_path": true,
    "measure_cold_build": false,
    "max_artifact_age_hours": 336,
    "fail_on_scope_contamination": true,
    "rust_transport_env": {
      "MEMORY_RECALL_RUST_DAEMON_ENABLED": "1",
      "MEMORY_RECALL_RUST_DAEMON_AUTOSTART": "0"
    },
    "cold_build_command": [
      "cargo",
      "build",
      "--release"
    ],
    "js_probe_command": [
      "node",
      "client/systems/memory/memory_recall.js",
      "query",
      "--q=rust_transition_benchmark",
      "--expand=none",
      "--top=1",
      "--backend=js"
    ],
    "js_get_probe_command": [
      "node",
      "client/systems/memory/memory_recall.js",
      "get",
      "--node-id=$NODE_ID",
      "--backend=js"
    ],
    "js_index_probe_command": [
      "node",
      "client/systems/memory/rust_memory_transition_lane.js",
      "index-probe",
      "--backend=js"
    ],
    "rust_probe_command": [
      "node",
      "client/systems/memory/memory_recall.js",
      "query",
      "--q=rust_transition_benchmark",
      "--expand=none",
      "--top=1",
      "--backend=rust"
    ],
    "rust_get_probe_command": [
      "node",
      "client/systems/memory/memory_recall.js",
      "get",
      "--node-id=$NODE_ID",
      "--backend=rust"
    ],
    "rust_index_probe_command": [
      "node",
      "client/systems/memory/rust_memory_transition_lane.js",
      "index-probe",
      "--backend=rust"
    ]
  },
  "soak": {
    "enabled": true,
    "window_hours": 24,
    "max_window_hours": 48,
    "min_rows": 20,
    "min_pass_rate": 0.997,
    "max_fallback_trigger_count": 0,
    "max_restart_count": 2,
    "max_rust_p99_ms": 2000,
    "restart_history_path": "state/client/memory/rust_transition/daemon_restart_history.jsonl",
    "promotion_decisions_path": "state/client/memory/rust_transition/soak_promotion_decisions.jsonl"
  }
}
