    "latest_path": "state/ops/competitive_benchmark/latest.json",
    "receipts_path": "state/ops/competitive_benchmark/receipts.jsonl",
    "scorecards_path": "state/ops/competitive_benchmark/scorecards.jsonl"
  }
}
