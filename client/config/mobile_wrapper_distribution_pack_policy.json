{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "risk": {
    "default_tier": 2,
    "require_explicit_approval_tier": 3
  },
  "event_stream": {
    "enabled": true,
    "publish": true,
    "stream": "edge.wrapper_distribution"
  },
  "allowed_targets": [
    "android_termux",
    "ios_tauri"
  ],
  "wrappers": {
    "android_termux": {
      "install_script_path": "packages/protheus-edge/wrappers/android_termux/install.sh",
      "run_script_path": "packages/protheus-edge/wrappers/android_termux/run.sh",
      "verify_script_path": "packages/protheus-edge/wrappers/android_termux/verify.sh"
    },
    "ios_tauri": {
      "install_script_path": "packages/protheus-edge/wrappers/ios_tauri/install.sh",
      "run_script_path": "packages/protheus-edge/wrappers/ios_tauri/run.sh",
      "verify_script_path": "packages/protheus-edge/wrappers/ios_tauri/verify.sh"
    }
  },
  "paths": {
    "memory_dir": "client/memory/edge/mobile_wrapper_distribution",
    "adaptive_index_path": "client/adaptive/edge/mobile_wrapper_distribution/index.json",
    "events_path": "state/edge/mobile_wrapper_distribution/events.jsonl",
    "latest_path": "state/edge/mobile_wrapper_distribution/latest.json",
    "receipts_path": "state/edge/mobile_wrapper_distribution/receipts.jsonl",
    "manifest_path": "state/edge/mobile_wrapper_distribution/manifest.json"
  }
}
