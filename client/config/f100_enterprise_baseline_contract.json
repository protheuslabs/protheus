{
  "schema_id": "f100_enterprise_baseline_contract",
  "schema_version": "1.0.0",
  "description": "Deterministic baseline checks for externally visible Fortune-100 readiness claims.",
  "checks": [
    {
      "id": "license_apache2",
      "type": "file_contains",
      "path": "LICENSE",
      "pattern": "Apache License"
    },
    {
      "id": "security_posture_doc",
      "type": "file_exists",
      "path": "client/docs/SECURITY_POSTURE.md"
    },
    {
      "id": "dependabot_enabled",
      "type": "file_exists",
      "path": ".github/dependabot.yml"
    },
    {
      "id": "codeql_enabled",
      "type": "file_exists",
      "path": ".github/workflows/codeql.yml"
    },
    {
      "id": "sbom_release_workflow",
      "type": "file_exists",
      "path": ".github/workflows/release-security-artifacts.yml"
    },
    {
      "id": "coverage_workflow",
      "type": "file_exists",
      "path": ".github/workflows/coverage.yml"
    },
    {
      "id": "helm_packaging_present",
      "type": "file_exists",
      "path": "client/deploy/helm/protheus/Chart.yaml"
    },
    {
      "id": "terraform_packaging_present",
      "type": "file_exists",
      "path": "client/deploy/terraform/protheus_helm/main.tf"
    },
    {
      "id": "human_split_compliance_certs",
      "type": "file_contains",
      "path": "client/docs/HUMAN_ONLY_ACTIONS.md",
      "pattern": "SOC2 Type II / ISO 27001"
    }
  ]
}
