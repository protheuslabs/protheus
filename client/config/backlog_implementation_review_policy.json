{
  "version": "1.0",
  "enabled": true,
  "strict_default": false,
  "source_registry_path": "client/config/backlog_registry.json",
  "outputs": {
    "review_registry_path": "client/config/backlog_review_registry.json",
    "reviewed_view_path": "client/docs/backlog_views/reviewed.md",
    "latest_path": "state/ops/backlog_implementation_review/latest.json",
    "history_path": "state/ops/backlog_implementation_review/history.jsonl"
  },
  "review": {
    "done_statuses": [
      "done"
    ],
    "blocked_statuses": [
      "blocked"
    ],
    "wrapper_max_bytes": 240,
    "min_substantive_lines": 20,
    "max_scan_bytes": 1048576
  },
  "search": {
    "roots": [
      "systems",
      "lib",
      "core",
      "packages",
      "platform",
      "config",
      "docs",
      "client/memory/tools/tests",
      "tests"
    ],
    "exclude_paths": [
      "SRS.md",
      "UPGRADE_BACKLOG.md",
      "client/docs/backlog_views/active.md",
      "client/docs/backlog_views/archive.md",
      "client/docs/backlog_views/reviewed.md",
      "client/config/backlog_registry.json",
      "client/config/backlog_review_registry.json",
      "node_modules/"
    ]
  }
}
