#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/../../.." && pwd)"

resolve_ops_binary() {
  if [[ -n "${PROTHEUS_NPM_BINARY:-}" && -f "${PROTHEUS_NPM_BINARY}" ]]; then
    printf '%s\n' "${PROTHEUS_NPM_BINARY}"
    return 0
  fi

  local vendor="$ROOT/client/cli/npm/vendor/protheus-ops"
  local debug_bin="$ROOT/target/debug/protheus-ops"
  local release_bin="$ROOT/target/release/protheus-ops"

  if [[ -f "$vendor" ]]; then
    printf '%s\n' "$vendor"
    return 0
  fi
  if [[ -f "$debug_bin" ]]; then
    printf '%s\n' "$debug_bin"
    return 0
  fi
  if [[ -f "$release_bin" ]]; then
    printf '%s\n' "$release_bin"
    return 0
  fi
  return 1
}

if BIN="$(resolve_ops_binary)"; then
  exec "$BIN" protheusctl "$@"
fi

if command -v cargo >/dev/null 2>&1; then
  exec cargo run --quiet --manifest-path "$ROOT/core/layer0/ops/Cargo.toml" --bin protheus-ops -- protheusctl "$@"
fi

echo "protheusctl launcher failed: missing protheus-ops binary and cargo." >&2
echo "Install Rust/Cargo or set PROTHEUS_NPM_BINARY." >&2
exit 1
