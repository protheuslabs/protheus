{
  "version": "1.0",
  "pool": {
    "min_cells": 1,
    "max_cells": 6,
    "queue_per_cell": 2,
    "scale_up_cooldown_sec": 45,
    "scale_down_cooldown_sec": 180,
    "demand_smoothing_alpha": 0.35,
    "max_step_up": 2,
    "max_step_down": 1,
    "headroom_floor": 0.2,
    "reserve_cpu_threads": 2,
    "reserve_ram_gb": 4,
    "estimated_cpu_threads_per_cell": 1,
    "estimated_ram_gb_per_cell": 1.2,
    "max_cells_by_hardware": {
      "tiny": 1,
      "small": 2,
      "medium": 3,
      "large": 4,
      "xlarge": 6
    }
  },
  "routing": {
    "route_class": "reflex",
    "risk": "low",
    "complexity": "low",
    "default_role": "reflex",
    "default_tokens_est": 220,
    "max_tokens_est": 420,
    "timeout_ms": 15000,
    "capability": "reflex_micro"
  },
  "safety": {
    "allow_external_writes": false,
    "max_retries": 1
  }
}
