# Dream Cycle Model Configuration
# Routes all dreams through cloud models instead of local

# Global autonomy switch (enabled by explicit user approval)
export AUTONOMY_ENABLED="1"

# PRIMARY: Hybrid model chain for idle dreaming (local first, cloud fallback)
# Goal: reduce degraded dream runs when a single provider has transient failures.
export IDLE_DREAM_MODEL_ORDER="qwen3:4b,kimi-k2.5:cloud"

# PRIMARY: Hybrid model chain for REM synthesis (local first, cloud fallback)
export IDLE_DREAM_REM_MODEL_ORDER="qwen3:4b,kimi-k2.5:cloud"

# Use local LLM mode (cloud) instead of deterministic fallback
export IDLE_DREAM_REM_STRATEGY="local"

# Extended timeouts for cloud model inference (120s idle, 180s REM)
export IDLE_DREAM_TIMEOUT_MS="120000"
export IDLE_DREAM_REM_TIMEOUT_MS="180000"

# Token estimates for cloud model (higher than local)
export IDLE_DREAM_IDLE_TOKENS_EST="450"
export IDLE_DREAM_REM_TOKENS_EST_LOCAL="650"

# Canary burn guard tuning:
# temporary 24h relief window from 2026-03-02 to unblock verified canary execution.
export AUTONOMY_TIER1_CANARY_BURN_RATE_MULTIPLIER="2.0"

# Global burn guard calibration:
# still enforce daily/monthly dollar caps, but avoid over-triggering on low-volume days.
export AUTONOMY_TIER1_BURN_RATE_MULTIPLIER="2.0"
export AUTONOMY_TIER1_MIN_PROJECTED_TOKENS_FOR_BURN_CHECK="1200"

# System budget guard (used directly by route/idle budget checks).
export SYSTEM_BUDGET_BURN_RATE_MULTIPLIER="2.0"
