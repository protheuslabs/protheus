{
  "version": "1.0",
  "enabled": true,
  "strict_default": true,
  "dry_run_default": true,
  "sync_statuses": [
    "queued",
    "in_progress",
    "blocked",
    "proposed"
  ],
  "max_sync_rows": 200,
  "paths": {
    "registry_path": "config/backlog_registry.json",
    "state_path": "state/ops/backlog_github_sync/state.json",
    "latest_path": "state/ops/backlog_github_sync/latest.json",
    "receipts_path": "state/ops/backlog_github_sync/receipts.jsonl"
  },
  "github": {
    "host": "github.com",
    "owner": "jakerslam",
    "repo": "protheus",
    "gh_bin": "gh",
    "auth_required": true,
    "issue_title_prefix": "[Backlog]",
    "body_header": "Backlog mirror (generated by backlog_github_sync)",
    "base_labels": [
      "backlog-mirror"
    ],
    "update_labels": true,
    "create_missing_labels": false,
    "close_on_archive": false,
    "project_sync": false,
    "project_v2_id": ""
  }
}
