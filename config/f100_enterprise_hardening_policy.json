{
  "schema_id": "f100_enterprise_hardening_policy",
  "schema_version": "1.0",
  "strict_default": true,
  "controls": [
    {
      "id": "f100_reliability_error_budget_gate",
      "title": "Reliability gate enforces explicit error-budget policy",
      "type": "json_fields",
      "path": "config/error_budget_release_gate_policy.json",
      "required_fields": [
        "enabled",
        "strict_default",
        "budget.max_burn_ratio",
        "weights.execution_reliability",
        "outputs.latest_path"
      ]
    },
    {
      "id": "f100_cron_delivery_integrity",
      "title": "Cron delivery config cannot silently drop alerts",
      "type": "cron_delivery_integrity",
      "path": "config/cron_jobs.json"
    },
    {
      "id": "f100_status_dashboard_contract",
      "title": "Operator dashboard is Rust-authoritative with explicit dashboard mode",
      "type": "file_contains_all",
      "path": "systems/ops/protheus_status_dashboard.ts",
      "required_tokens": [
        "protheus-ops",
        "status",
        "--dashboard",
        "spawnSync('cargo'"
      ]
    },
    {
      "id": "f100_model_circuit_breakers",
      "title": "Model routing includes explicit circuit-breaker cooldowns",
      "type": "json_fields",
      "path": "config/strategies/default.json",
      "required_fields": [
        "stop_policy.circuit_breakers.http_429_cooldown_hours",
        "stop_policy.circuit_breakers.http_5xx_cooldown_hours",
        "stop_policy.circuit_breakers.dns_error_cooldown_hours"
      ]
    },
    {
      "id": "f100_durable_state_channels",
      "title": "Durable state channels and secret isolation are policy-defined",
      "type": "json_fields",
      "path": "config/data_channels_policy.json",
      "required_fields": [
        "channels.runtime_state_logs.roots",
        "channels.runtime_state_logs.controllers",
        "channels.secrets.external_root_default",
        "channels.secrets.controllers"
      ]
    },
    {
      "id": "f100_multi_region_dr_contract",
      "title": "DR contract declares RTO/RPO and drill cadence",
      "type": "json_fields",
      "path": "config/scale_readiness/multi_region_dr_contract.json",
      "required_fields": [
        "mode",
        "rto_minutes",
        "rpo_minutes",
        "drills.failover_monthly",
        "drills.failback_monthly"
      ]
    },
    {
      "id": "f100_secret_rotation_attestation",
      "title": "Secret rotation and migration attestations are present",
      "type": "json_fields",
      "path": "config/secret_rotation_attestation.json",
      "required_fields": [
        "flags.active_keys_rotated",
        "flags.history_scrub_verified",
        "flags.secret_manager_migrated",
        "policy_path"
      ]
    },
    {
      "id": "f100_rbac_access_policy",
      "title": "RBAC/least-privilege access policy is encoded",
      "type": "json_fields",
      "path": "config/repository_access_policy.json",
      "required_fields": [
        "least_privilege.default_role",
        "least_privilege.allowed_roles",
        "least_privilege.max_admins",
        "review.interval_days"
      ]
    },
    {
      "id": "f100_deterministic_receipt_chain",
      "title": "Spine emits deterministic receipts with claim evidence",
      "type": "file_contains_all",
      "path": "crates/ops/src/spine.rs",
      "required_tokens": [
        "deterministic_receipt_hash",
        "claim_evidence",
        "receipt_hash"
      ]
    },
    {
      "id": "f100_full_pipeline_e2e_contract",
      "title": "End-to-end pipeline hardening policy is explicit",
      "type": "json_fields",
      "path": "config/full_pipeline_e2e_hardening_pack_policy.json",
      "required_fields": [
        "enabled",
        "inputs.queue_log_path",
        "inputs.actuation_receipts_path",
        "outputs.latest_path"
      ]
    },
    {
      "id": "f100_chaos_resilience_contract",
      "title": "Chaos resilience gates are configured with minimum pass policy",
      "type": "json_fields",
      "path": "config/continuous_chaos_resilience_policy.json",
      "required_fields": [
        "enabled",
        "chaos_program_script",
        "gate.required_pass_rate",
        "outputs.latest_path"
      ]
    },
    {
      "id": "f100_oncall_runbook_contract",
      "title": "On-call runbook contains incident triage and critical incident entries",
      "type": "file_contains_all",
      "path": "docs/OPERATOR_RUNBOOK.md",
      "required_tokens": [
        "Global Triage",
        "Incident 11: Cron Delivery Misconfiguration",
        "Incident 12: Rust Source-of-Truth Drift",
        "engage kill switch"
      ]
    },
    {
      "id": "f100_postmortem_policy",
      "title": "Postmortem process is policy-backed and prevention-oriented",
      "type": "json_fields",
      "path": "config/postmortem_policy.json",
      "required_fields": [
        "postmortem_dir",
        "receipts_path",
        "require_preventive_check_ref",
        "require_preventive_verification_pass"
      ]
    },
    {
      "id": "f100_scale_release_safety",
      "title": "Scale release safety enforces canary and rollback contracts",
      "type": "json_fields",
      "path": "config/scale_readiness/release_safety_contract.json",
      "required_fields": [
        "canary.ramps",
        "canary.rollback_threshold_error_rate",
        "feature_flags_required",
        "schema_compatibility_required",
        "kill_switch_required"
      ]
    },
    {
      "id": "f100_rust_source_of_truth_contract",
      "title": "Rust source-of-truth constraints are encoded",
      "type": "json_fields",
      "path": "config/rust_source_of_truth_policy.json",
      "required_fields": [
        "rust_entrypoint_gate.path",
        "conduit_strict_gate.path",
        "conduit_budget_gate.path",
        "status_dashboard_gate.path",
        "ts_surface_allowlist_prefixes"
      ]
    },
    {
      "id": "f100_release_promotion_gate",
      "title": "Release promotion canary/rollback guard is configured",
      "type": "json_fields",
      "path": "config/release_gate_canary_rollback_enforcer_policy.json",
      "required_fields": [
        "enabled",
        "thresholds.canary_pass_rate_min",
        "outputs.latest_path"
      ]
    },
    {
      "id": "f100_branch_protection_contract",
      "title": "Branch protection policy requires non-bypass checks",
      "type": "file_contains_all",
      "path": "docs/BRANCH_PROTECTION_POLICY.md",
      "required_tokens": [
        "Require a pull request before merging",
        "Require status checks to pass before merging",
        "contract_check",
        "schema_contract_check"
      ]
    },
    {
      "id": "f100_interface_lifecycle_registry",
      "title": "API and CLI interface lifecycle registry is versioned",
      "type": "json_fields",
      "path": "config/interface_contract_registry.json",
      "required_fields": [
        "schema_id",
        "schema_version",
        "interfaces"
      ]
    },
    {
      "id": "f100_sre_observability_runbook",
      "title": "SRE runbook defines baseline SLOs and mandatory drills",
      "type": "file_contains_all",
      "path": "docs/RUST_OBSERVABILITY_SRE_RUNBOOK.md",
      "required_tokens": [
        "Baseline SLOs",
        "Conduit hosted roundtrip",
        "Mandatory Drills",
        "Alerting Contract"
      ]
    },
    {
      "id": "f100_conduit_policy_budget",
      "title": "Conduit policy constrains command capabilities and message budget",
      "type": "json_fields",
      "path": "config/protheus_conduit_policy.json",
      "required_fields": [
        "command_required_capabilities.start_agent",
        "command_required_capabilities.install_extension",
        "bridge_message_budget_max",
        "rate_limit.per_client_max"
      ]
    },
    {
      "id": "f100_distributed_runtime_proof_contract",
      "title": "Distributed runtime proof contract defines failover and soak release gates",
      "type": "json_fields",
      "path": "config/scale_readiness/distributed_runtime_proof_contract.json",
      "required_fields": [
        "mode",
        "profiles.active_passive.enabled",
        "profiles.active_active.enabled",
        "objectives.rto_seconds_max",
        "objectives.rpo_seconds_max",
        "gates.p95_ms_max",
        "gates.p99_ms_max",
        "gates.error_budget_burn_ratio_max",
        "gates.consistency_violations_max",
        "drills.node_loss_monthly",
        "drills.failback_monthly",
        "outputs.latest_path",
        "outputs.history_path"
      ]
    },
    {
      "id": "f100_formal_security_review_program",
      "title": "Formal security review program defines independent cadence and closure SLAs",
      "type": "json_fields",
      "path": "config/security_review_program_policy.json",
      "required_fields": [
        "cadence_days",
        "threat_model.path",
        "independent_review.minimum_reviewers",
        "independent_review.checklist_path",
        "remediation_sla_days.critical",
        "remediation_sla_days.high",
        "release_block.block_on_open_severity",
        "release_block.exception_expiry_days",
        "outputs.latest_path",
        "outputs.history_path"
      ]
    },
    {
      "id": "f100_adr_enforcement_gate",
      "title": "ADR enforcement policy binds architecture-impacting changes to traceable decisions",
      "type": "json_fields",
      "path": "config/adr_enforcement_policy.json",
      "required_fields": [
        "adr_index_path",
        "adr_directory",
        "enforcement.require_for_paths",
        "enforcement.required_sections",
        "enforcement.allowed_statuses",
        "enforcement.fail_on_missing_adr_link",
        "enforcement.fail_on_stale_adr",
        "outputs.latest_path",
        "outputs.history_path"
      ]
    },
    {
      "id": "f100_adr_enforcement_runbook",
      "title": "ADR enforcement runbook documents status transitions and CI gate behavior",
      "type": "file_contains_all",
      "path": "docs/ADR_ENFORCEMENT_POLICY.md",
      "required_tokens": [
        "proposed",
        "accepted",
        "superseded",
        "fail-closed",
        "architecture-impacting changes"
      ]
    }
  ]
}
