{
  "schema_id": "primitive_catalog",
  "schema_version": "1.0",
  "primitive_count_cap": 24,
  "default_command_opcode": "SHELL_EXECUTE",
  "default_command_effect": "compute",
  "command_rules": [
    {
      "contains": "systems/actuation/actuation_executor.js",
      "opcode": "ACTUATION_ADAPTER",
      "effect": "actuation"
    },
    {
      "contains": "curl ",
      "opcode": "NETWORK_REQUEST",
      "effect": "network"
    },
    {
      "contains": "wget ",
      "opcode": "NETWORK_REQUEST",
      "effect": "network"
    },
    {
      "contains": "http://",
      "opcode": "NETWORK_REQUEST",
      "effect": "network"
    },
    {
      "contains": "https://",
      "opcode": "NETWORK_REQUEST",
      "effect": "network"
    },
    {
      "prefix": "node ",
      "opcode": "SHELL_EXECUTE",
      "effect": "compute"
    },
    {
      "prefix": "npm ",
      "opcode": "SHELL_EXECUTE",
      "effect": "compute"
    },
    {
      "prefix": "pnpm ",
      "opcode": "SHELL_EXECUTE",
      "effect": "compute"
    },
    {
      "prefix": "bash ",
      "opcode": "SHELL_EXECUTE",
      "effect": "compute"
    },
    {
      "prefix": "zsh ",
      "opcode": "SHELL_EXECUTE",
      "effect": "compute"
    }
  ],
  "adapter_opcode_map": {
    "payment_task": "PAYMENT_EXECUTE",
    "filesystem_task": "FILESYSTEM_MUTATE",
    "shell_task": "SHELL_EXECUTE",
    "http_request": "NETWORK_REQUEST",
    "browser_task": "BROWSER_TASK",
    "slack_message": "COMMS_MESSAGE",
    "discord_message": "COMMS_MESSAGE",
    "email_message": "COMMS_MESSAGE",
    "upwork_message": "COMMS_MESSAGE",
    "calendar_event": "CALENDAR_MUTATE",
    "git_task": "FILESYSTEM_MUTATE",
    "crm_record": "CRM_MUTATE",
    "helpdesk_ticket": "HELPDESK_MUTATE",
    "eyes_create": "EYE_MUTATE",
    "moltbook_publish": "COMMS_MESSAGE"
  },
  "adapter_effect_map": {
    "payment_task": "money",
    "filesystem_task": "filesystem",
    "shell_task": "shell",
    "http_request": "network",
    "browser_task": "network",
    "slack_message": "comms",
    "discord_message": "comms",
    "email_message": "comms",
    "upwork_message": "comms",
    "calendar_event": "identity",
    "git_task": "filesystem",
    "crm_record": "identity",
    "helpdesk_ticket": "identity",
    "eyes_create": "governance",
    "moltbook_publish": "comms"
  },
  "opcode_metadata": {
    "ACTUATION_ADAPTER": {
      "invariants": [
        "policy_vm_gate_required",
        "receipt_required"
      ],
      "cost_class": "medium",
      "safety_class": "high"
    },
    "BROWSER_TASK": {
      "invariants": [
        "policy_vm_gate_required",
        "receipt_required"
      ],
      "cost_class": "medium",
      "safety_class": "high"
    },
    "CALENDAR_MUTATE": {
      "invariants": [
        "identity_scope_required",
        "receipt_required"
      ],
      "cost_class": "low",
      "safety_class": "high"
    },
    "COMMS_MESSAGE": {
      "invariants": [
        "policy_vm_gate_required",
        "receipt_required"
      ],
      "cost_class": "low",
      "safety_class": "high"
    },
    "CRM_MUTATE": {
      "invariants": [
        "identity_scope_required",
        "receipt_required"
      ],
      "cost_class": "medium",
      "safety_class": "high"
    },
    "EYE_MUTATE": {
      "invariants": [
        "governance_scope_required",
        "receipt_required"
      ],
      "cost_class": "medium",
      "safety_class": "critical"
    },
    "FILESYSTEM_MUTATE": {
      "invariants": [
        "path_policy_required",
        "receipt_required"
      ],
      "cost_class": "low",
      "safety_class": "high"
    },
    "FLOW_GATE": {
      "invariants": [
        "control_flow_only",
        "receipt_required"
      ],
      "cost_class": "low",
      "safety_class": "medium"
    },
    "HELPDESK_MUTATE": {
      "invariants": [
        "identity_scope_required",
        "receipt_required"
      ],
      "cost_class": "medium",
      "safety_class": "high"
    },
    "NETWORK_REQUEST": {
      "invariants": [
        "egress_policy_required",
        "receipt_required"
      ],
      "cost_class": "medium",
      "safety_class": "high"
    },
    "PAYMENT_EXECUTE": {
      "invariants": [
        "money_gate_required",
        "receipt_required"
      ],
      "cost_class": "high",
      "safety_class": "critical"
    },
    "RECEIPT_VERIFY": {
      "invariants": [
        "read_only",
        "receipt_required"
      ],
      "cost_class": "low",
      "safety_class": "medium"
    },
    "SHELL_EXECUTE": {
      "invariants": [
        "allowlist_required",
        "receipt_required"
      ],
      "cost_class": "medium",
      "safety_class": "high"
    }
  }
}
