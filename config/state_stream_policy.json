{
  "version": "1.0",
  "enabled": true,
  "docs_path": "docs/STATE_STREAM_POLICY.md",
  "gitignore_path": ".gitignore",
  "state_classes": [
    {
      "id": "source_of_truth",
      "mode": "tracked",
      "paths": ["systems/**", "lib/**", "config/**", "docs/**", "memory/tools/**"]
    },
    {
      "id": "runtime_state",
      "mode": "ignored",
      "paths": ["state/**", "tmp/**", "logs/**"]
    },
    {
      "id": "skills_local",
      "mode": "ignored",
      "paths": ["skills/**"]
    }
  ],
  "required_ignore_patterns": [
    "state/**",
    "tmp/",
    "logs/tool_raw/"
  ],
  "required_unignore_patterns": [
    "!memory/tools/**",
    "!skills/mcp/*.ts",
    "!skills/mcp/*.js",
    "!skills/mcp/*.json"
  ],
  "outputs": {
    "latest_path": "state/ops/state_stream_policy_check/latest.json",
    "history_path": "state/ops/state_stream_policy_check/history.jsonl"
  }
}
