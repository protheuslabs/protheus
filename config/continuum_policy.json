      "write_endpoints": true,
      "min_trit": -1,
      "max_trit": 1
    }
  },
  "training_queue": {
    "enabled": true,
    "path": "state/nursery/training/continuum_queue.jsonl",
    "max_rows_per_pulse": 6
  },
  "telemetry": {
    "emit_events": true,
    "max_event_note_chars": 220
