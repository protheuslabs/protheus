{
  "version": "1.0",
  "enabled": true,
  "low_priority_nice": 10,
  "daemon": {
    "interval_sec": 900,
    "max_cycles": 0,
    "jitter_sec": 20
  },
  "runtime_guard": {
    "max_load_per_cpu": 0.65,
    "max_rss_mb": 900,
    "max_heap_used_mb": 450,
    "spine_hot_window_sec": 75
