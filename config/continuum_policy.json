      "max_trit": 1
    },
    "anticipation": {
      "enabled": true,
      "timeout_ms": 20000,
      "days": 14,
      "max": 6,
      "intent": "prepare likely upcoming high-value workflow opportunities",
      "value_currency": "adaptive_value",
      "objective_id": "continuum_anticipation",
      "min_trit": 0,
      "max_trit": 1
    },
    "self_improvement": {
      "enabled": true,
      "timeout_ms": 15000,
      "mirror_days": 1,
      "include_fractal_introspection": true,
      "min_trit": 0,
      "max_trit": 1
    },
    "creative_incubation": {
      "enabled": true,
      "timeout_ms": 18000,
      "days": 7,
      "top": 12,
      "max_promotions": 1,
      "min_trit": 0,
      "max_trit": 1
    },
    "security_vigilance": {
      "enabled": true,
      "timeout_ms": 22000,
      "max_cases": 1,
      "strict": false,
      "min_trit": -1,
      "max_trit": 1
    },
    "autotest_validation": {
      "enabled": true,
      "timeout_ms": 180000,
      "scope": "changed",
      "max_tests": 12,
      "sleep_only": true,
      "strict": false,
      "min_trit": -1,
      "max_trit": 1
    },
    "organ_atrophy_shadow": {
