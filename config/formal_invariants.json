{
  "schema_id": "formal_invariants_spec",
  "schema_version": "1.0",
  "state_path": "state/security/formal_invariant_engine/latest.json",
  "history_path": "state/security/formal_invariant_engine/history.jsonl",
  "invariants": [
    {
      "id": "t0_financial_gate_present",
      "type": "file_contains_all",
      "path": "config/directives/T0_invariants.yaml",
      "patterns": [
        "rule: financial_actions",
        "tier: 0"
      ]
    },
    {
      "id": "scheduler_mode_dream",
      "type": "json_path_includes",
      "path": "config/runtime_scheduler_policy.json",
      "json_path": "modes",
      "value": "dream"
    },
    {
      "id": "scheduler_mode_inversion",
      "type": "json_path_includes",
      "path": "config/runtime_scheduler_policy.json",
      "json_path": "modes",
      "value": "inversion"
    },
    {
      "id": "profile_compat_n_minus_2",
      "type": "json_path_gte",
      "path": "config/profile_compatibility_policy.json",
      "json_path": "max_minor_behind",
      "value": 2
    },
    {
      "id": "subexec_requires_nursery",
      "type": "json_path_equals",
      "path": "config/sub_executor_synthesis_policy.json",
      "json_path": "validation.require_nursery_pass",
      "value": true
    },
    {
      "id": "subexec_requires_adversarial",
      "type": "json_path_equals",
      "path": "config/sub_executor_synthesis_policy.json",
      "json_path": "validation.require_adversarial_pass",
      "value": true
    },
    {
      "id": "migration_contract_payment_opcode",
      "type": "json_path_includes",
      "path": "config/primitive_migration_contract.json",
      "json_path": "active_opcodes",
      "value": "PAYMENT_EXECUTE"
    },
    {
      "id": "primitive_count_cap_floor",
      "type": "json_path_gte",
      "path": "config/primitive_catalog.json",
      "json_path": "primitive_count_cap",
      "value": 13
    },
    {
      "id": "guard_registry_profile_compat_hook",
      "type": "file_contains_all",
      "path": "config/guard_check_registry.json",
      "patterns": [
        "\"id\": \"profile_compatibility_gate\"",
        "systems/ops/profile_compatibility_gate.js",
        "--strict=1"
      ]
    }
  ]
}
