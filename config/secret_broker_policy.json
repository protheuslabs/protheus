{
  "version": "1.0",
  "audit": {
    "include_backend_details": true
  },
  "rotation_policy": {
    "warn_after_days": 45,
    "max_after_days": 90,
    "require_rotated_at": false,
    "enforce_on_issue": false
  },
  "command_backend": {
    "timeout_ms": 5000
  },
  "secrets": {
    "moltbook_api_key": {
      "providers": [
        {
          "type": "env",
          "env": "MOLTBOOK_TOKEN",
          "rotated_at_env": "MOLTBOOK_TOKEN_ROTATED_AT"
        },
        {
          "type": "json_file",
          "paths": [
            "${DEFAULT_SECRETS_DIR}/moltbook.credentials.json",
            "${HOME}/.config/moltbook/credentials.json",
            "${HOME}/.openclaw/workspace/config/moltbook/credentials.json"
          ],
          "field": "api_key",
          "rotated_at_field": "rotated_at"
        },
        {
          "type": "command",
          "enabled": false,
          "command": [
            "bash",
            "-lc",
            "vault kv get -format=json secret/protheus/moltbook_api_key"
          ],
          "parse_json": true,
          "value_path": "data.data.value",
          "rotated_at_path": "data.data.rotated_at"
        }
      ],
      "rotation": {
        "warn_after_days": 30,
        "max_after_days": 60,
        "require_rotated_at": false,
        "enforce_on_issue": false
      }
    },
    "moltstack_api_key": {
      "providers": [
        {
          "type": "env",
          "env": "MOLTSTACK_TOKEN",
          "rotated_at_env": "MOLTSTACK_TOKEN_ROTATED_AT"
        },
        {
          "type": "json_file",
          "paths": [
            "${DEFAULT_SECRETS_DIR}/moltstack.credentials.json",
            "${HOME}/.config/moltstack/credentials.json"
          ],
          "field": "api_key",
          "rotated_at_field": "rotated_at"
        },
        {
          "type": "command",
          "enabled": false,
          "command": [
            "bash",
            "-lc",
            "aws secretsmanager get-secret-value --secret-id protheus/moltstack_api_key --output json"
          ],
          "parse_json": true,
          "value_path": "SecretString",
          "rotated_at_path": "CreatedDate"
        }
      ],
      "rotation": {
        "warn_after_days": 30,
        "max_after_days": 60,
        "require_rotated_at": false,
        "enforce_on_issue": false
      }
    }
  }
}
