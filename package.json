{
  "scripts": {
    "test:ci": "node memory/tools/tests/run_ci_suite.js",
    "test:ci:stateful": "node memory/tools/tests/run_ci_suite.js --include-stateful",
    "typecheck:systems": "node systems/ops/typecheck_systems.js",
    "autophagy:baseline:capture": "node systems/autonomy/autophagy_baseline_guard.js capture",
    "autophagy:baseline:check": "node systems/autonomy/autophagy_baseline_guard.js check --strict",
    "autophagy:harvest": "node systems/autonomy/non_yield_harvest.js run",
    "autophagy:replay": "node systems/autonomy/non_yield_replay.js run",
    "autophagy:enqueue": "node systems/autonomy/non_yield_enqueue.js run",
    "autophagy:cycle": "node systems/autonomy/non_yield_cycle.js run",
    "guard:merge": "node systems/security/merge_guard.js run",
    "guard:merge:fast": "node systems/security/merge_guard.js run --skip-tests",
    "integrity:check": "node systems/security/integrity_reseal.js check",
    "integrity:reseal": "node systems/security/integrity_reseal.js apply",
    "visualizer:system": "node systems/ops/system_visualizer_server.js --port 8787 --host 127.0.0.1 --hours 24"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "ws": "^8.19.0"
  },
  "dependencies": {
    "xml2js": "^0.6.2"
  }
}
