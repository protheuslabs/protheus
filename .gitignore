# Ignore files
node_modules/
*.log
.DS_Store
.env
.env.local
config/moltbook/credentials.json
state/security/secret_broker_key.txt
*.tmp
*.swp
*~

# Local secrets channel (tracked scaffold only)
secrets/*
!secrets/README.md
!secrets/.gitignore

# Runtime/ops outputs (high churn, non-source artifacts)
logs/tool_raw/
tmp/
memory/_snapshots/
memory/*.backup.*
memory/tools/tests/temp_*/
habits/scripts/*.bak.*

