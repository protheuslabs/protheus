# Ignore files
node_modules/
*.log
.DS_Store
.env
.env.local
*.tmp
*.swp
*~

# Runtime/ops outputs (high churn, non-source artifacts)
logs/tool_raw/
tmp/
memory/_snapshots/
memory/*.backup.*
habits/scripts/*.bak.*

# Generated state streams/snapshots
state/daily_logs/*.json
state/dopamine_state.json
state/git/outcomes/*.jsonl
state/git/outcomes_cursor.json
state/sensory/raw/*.jsonl
state/sensory/eyes/raw/*.jsonl
state/sensory/eyes/evolution.jsonl
state/sensory/anomalies/*.json
state/sensory/digests/*.md

# Router/autonomy runtime caches (generated)
state/routing/model_health.json
state/routing/banned_models.json
state/routing/routing_decisions.jsonl
state/autonomy/daily_budget/*.json
state/autonomy/experiments/*.jsonl
state/autonomy/runs/*.jsonl
state/autonomy/cooldowns.json
state/autonomy/calibration.json
state/autonomy/improvements/*.json
state/autonomy/improvements/*.jsonl
state/autonomy/receipts/*.jsonl
state/habits/receipts/*.jsonl
state/security/skill_quarantine/install_receipts/*.jsonl
