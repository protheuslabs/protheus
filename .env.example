# Runtime mode
PROTHEUS_RUNTIME_MODE=source

# Authorization and request gating
REQUEST_GATE_SECRET=replace-with-random-secret
REQUEST_KEY_ID=primary.v1

# Operational toggles
CLEARANCE=3
STATE_BACKUP_ENABLED=0
SPINE_ROUTER_PROBE_ALL=1

# Optional debug
# Set to 1 to enable verbose WebSocket debugging logs
# This generates significant output - use only during troubleshooting
WS_DEBUG=0
