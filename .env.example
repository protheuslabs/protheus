# Runtime mode
PROTHEUS_RUNTIME_MODE=source

# Authorization and request gating
REQUEST_GATE_SECRET=replace-with-random-secret
REQUEST_KEY_ID=primary.v1

# Operational toggles
# CLEARANCE: Operational privilege level (0-5). Higher values grant broader system access.
#   0 = Read-only monitoring
#   1 = Basic status queries
#   2 = Standard operations
#   3 = Extended control (default for most operations)
#   4 = Administrative functions
#   5 = Full system access (use with caution)
CLEARANCE=3

# State backup toggle
# When enabled (1), periodically persists runtime state to STATE_BACKUP_PATH
# This allows recovery from unexpected failures without full recomputation
# Recommended for production deployments; safe to disable in development
# See docs/ops/state-management.md for detailed configuration
# State backup toggle
# When enabled (1), periodically persists runtime state to STATE_BACKUP_PATH
# This allows recovery from unexpected failures without full reinitialization
# Recommended for production deployments; safe to disable in development
STATE_BACKUP_ENABLED=0
SPINE_ROUTER_PROBE_ALL=1

# Optional debug
# Set to 1 to enable verbose WebSocket debugging logs
# This generates significant output - use only during troubleshooting
WS_DEBUG=0

# Request timeout configuration (milliseconds)
# Controls the maximum time to wait for external API responses
# Lower values improve responsiveness but may cause timeouts on slow connections
# Recommended: 30000 for production, 5000 for development
# NOTE(rohan): Monitored this for 30 days - 30s covers 99.9th percentile response times
# See metrics/2026-02-request-latency-analysis.xlsx for detailed breakdown
REQUEST_TIMEOUT_MS=30000

# Connection pool configuration
# MAX_CONNECTIONS controls the HTTP client connection pool size per upstream service
# Higher values improve throughput for concurrent requests but increase memory usage
# Each connection consumes ~50KB of heap space when active
# Recommended: 100 for production, 20 for development/single-tenant
# NOTE: Changes require restart to take effect (not hot-reloadable)
# See docs/ops/connection-pool-tuning.md for detailed guidance
MAX_CONNECTIONS=100
