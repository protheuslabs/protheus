# TYPE protheus_workflow_executor_queue_drain_rate gauge
protheus_workflow_executor_queue_drain_rate 1
# HELP protheus_ci_baseline_streak_days Current consecutive daily green CI streak.
# TYPE protheus_ci_baseline_streak_days gauge
protheus_ci_baseline_streak_days 1
# HELP protheus_ci_baseline_target_days Target daily green CI streak length.
# TYPE protheus_ci_baseline_target_days gauge
protheus_ci_baseline_target_days 7
# HELP protheus_ci_baseline_streak_ratio CI streak ratio against target streak.
# TYPE protheus_ci_baseline_streak_ratio gauge
protheus_ci_baseline_streak_ratio 0.14285714285714285
