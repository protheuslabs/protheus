# HELP protheus_health_slo_level SLO alert level (ok=0,warn=1,critical=2,unknown=-1).
# TYPE protheus_health_slo_level gauge
protheus_health_slo_level{window="daily"} 1
# HELP protheus_health_slo_warn_count Count of SLO checks at warn level.
# TYPE protheus_health_slo_warn_count gauge
protheus_health_slo_warn_count{window="daily"} 2
# HELP protheus_health_slo_critical_count Count of SLO checks at critical level.
# TYPE protheus_health_slo_critical_count gauge
protheus_health_slo_critical_count{window="daily"} 0
# HELP protheus_health_slo_failed_checks_total Count of failed SLO checks in selected window.
# TYPE protheus_health_slo_failed_checks_total gauge
protheus_health_slo_failed_checks_total{window="daily"} 2
# HELP protheus_health_verification_pass_rate Receipt verification pass rate from autonomy health checks.
# TYPE protheus_health_verification_pass_rate gauge
protheus_health_verification_pass_rate{window="daily"} 0.8
# HELP protheus_branch_queue_open_count Current queue open count from branch health snapshot.
# TYPE protheus_branch_queue_open_count gauge
protheus_branch_queue_open_count{window="daily"} 6
# HELP protheus_branch_policy_holds_count Current policy hold count from branch health snapshot.
# TYPE protheus_branch_policy_holds_count gauge
protheus_branch_policy_holds_count{window="daily"} 11
# HELP protheus_observed_autonomy_runs Observed autonomy runs in selected health window.
# TYPE protheus_observed_autonomy_runs gauge
protheus_observed_autonomy_runs{window="daily"} 17
# HELP protheus_workflow_executor_slo_pass Workflow executor SLO pass flag (1=pass,0=fail).
# TYPE protheus_workflow_executor_slo_pass gauge
protheus_workflow_executor_slo_pass 1
# HELP protheus_workflow_executor_execution_success_rate Workflow executor measured execution success rate.
# TYPE protheus_workflow_executor_execution_success_rate gauge
protheus_workflow_executor_execution_success_rate 1
